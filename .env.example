# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Telegram API (получить на https://my.telegram.org)
# нужны для Local Bot API (контейнер bot-api) — файлы до 2 ГБ
# Если не используете Local Bot API — можно оставить пустыми
API_ID=
API_HASH=

# Юзернейм бота (без @) — используется в подписи к медиа
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_facebook
DB_USER=bot_4_facebook
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую
ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== КЭШ ====================

# Кэш скачиваний в БД (дни) — не перекачиваем одно и то же видео
CACHE_TTL_DAYS=1

# ==================== ЛИМИТЫ ====================

# Максимальный размер файла (байты). По умолчанию 2 ГБ (Local Bot API)
# MAX_FILE_SIZE=2147483648
